# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo .env (com dados reais) para o GitHub.

# String de conexao do banco Postgres (voce pega isso no Supabase)
DATABASE_URL="postgresql://usuario:senha@host:5432/postgres"

# Chave secreta para gerar os tokens de login. Troque por qualquer texto aleatorio e longo.
JWT_SECRET="troque_isso_por_um_texto_secreto_bem_grande_e_aleatorio"

# Porta em que o servidor backend vai rodar localmente
PORT=3001

# URL do frontend (usado para liberar o CORS). Em producao, coloque a URL do Vercel.
FRONTEND_URL="http://localhost:5173"
