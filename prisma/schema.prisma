// Schema do banco de dados - Distribuidora M&P
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDEDOR
}

enum StatusPedido {
  PENDENTE
  EM_ROTA
  ENTREGUE
  CANCELADO
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO
  FIADO
}

enum StatusPagamento {
  PAGO
  PENDENTE
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(VENDEDOR)
  createdAt DateTime @default(now())

  clientes  Cliente[]
  pedidos   Pedido[]
}

model Cliente {
  id         Int      @id @default(autoincrement())
  nome       String
  endereco   String
  telefone   String?
  categoria  String?  // Ex: Bar, Mercado, Restaurante, Residencial
  observacoes String?
  createdAt  DateTime @default(now())

  vendedorId Int?
  vendedor   Usuario? @relation(fields: [vendedorId], references: [id])

  pedidos    Pedido[]
}

model Produto {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  categoria   String?  @default("Geral") // Ex: Cerveja, Refrigerante, Destilado, Água
  unidade     String   @default("Unidade") // Ex: Caixa, Fardo, Garrafa, Unidade
  preco       Float
  desconto    Float    @default(0) // percentual, ex: 10 = 10%
  estoque     Int      @default(0)
  estoqueMin  Int      @default(5) // alerta de estoque baixo
  createdAt   DateTime @default(now())

  itensPedido ItemPedido[]
}

model Pedido {
  id              Int             @id @default(autoincrement())
  valorTotal      Float
  status          StatusPedido    @default(PENDENTE)
  formaPagamento  FormaPagamento  @default(DINHEIRO)
  statusPagamento StatusPagamento @default(PENDENTE)
  observacoes     String?
  createdAt       DateTime        @default(now())

  clienteId  Int
  cliente    Cliente       @relation(fields: [clienteId], references: [id])

  vendedorId Int
  vendedor   Usuario       @relation(fields: [vendedorId], references: [id])

  itens      ItemPedido[]
}

model ItemPedido {
  id         Int     @id @default(autoincrement())
  quantidade Int
  precoUnit  Float   // preco já com desconto aplicado, no momento da venda

  pedidoId   Int
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  produtoId  Int
  produto    Produto @relation(fields: [produtoId], references: [id])
}
