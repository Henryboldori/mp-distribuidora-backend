generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDEDOR
}

enum StatusPedido {
  PENDENTE
  EM_ROTA
  ENTREGUE
  CANCELADO
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO
  FIADO
}

enum StatusPagamento {
  PAGO
  PENDENTE
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(VENDEDOR)
  createdAt DateTime @default(now())

  clientes  Cliente[]
  pedidos   Pedido[]
}

model Cliente {
  id         Int      @id @default(autoincrement())
  nome       String
  endereco   String?
  telefone   String?
  categoria  String?
  observacoes String?
  createdAt  DateTime @default(now())

  vendedorId Int?
  vendedor   Usuario? @relation(fields: [vendedorId], references: [id])

  pedidos    Pedido[]
}

model Produto {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  categoria   String?  @default("Geral")
  unidade     String   @default("Unidade")
  preco       Float
  desconto    Float    @default(0)
  estoque     Int      @default(0)
  estoqueMin  Int      @default(5)
  createdAt   DateTime @default(now())

  itensPedido ItemPedido[]
  entradas    EntradaEstoque[]
}

model Fornecedor {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String?
  createdAt DateTime @default(now())

  entradas  EntradaEstoque[]
}

model EntradaEstoque {
  id             Int      @id @default(autoincrement())
  quantidade     Int
  custoUnitario  Float?
  createdAt      DateTime @default(now())

  produtoId      Int
  produto        Produto     @relation(fields: [produtoId], references: [id])

  fornecedorId   Int?
  fornecedor     Fornecedor? @relation(fields: [fornecedorId], references: [id])
}

model Pedido {
  id              Int             @id @default(autoincrement())
  valorTotal      Float
  status          StatusPedido    @default(PENDENTE)
  formaPagamento  FormaPagamento  @default(DINHEIRO)
  statusPagamento StatusPagamento @default(PENDENTE)
  observacoes     String?
  createdAt       DateTime        @default(now())

  clienteId  Int
  cliente    Cliente       @relation(fields: [clienteId], references: [id])

  vendedorId Int
  vendedor   Usuario       @relation(fields: [vendedorId], references: [id])

  itens      ItemPedido[]
}

model ItemPedido {
  id         Int     @id @default(autoincrement())
  quantidade Int
  precoUnit  Float
  nomeAvulso String?
  unidadeAvulso String?

  pedidoId   Int
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  produtoId  Int?
  produto    Produto? @relation(fields: [produtoId], references: [id])
}